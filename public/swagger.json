{
  "openapi": "3.0.0",
  "info": {
    "title": "DTTOT & PEP API",
    "description": "API untuk pengecekan data DTTOT dan PEP",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "Current Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "paths": {
    "/api/v1/login": {
      "post": {
        "summary": "Login to get API Token",
        "description": "Authenticates a user and returns the static API token if credentials are valid.",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string", "example": "admin" },
                  "password": { "type": "string", "example": "password123" }
                }
              }
            },
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string", "example": "admin" },
                  "password": { "type": "string", "example": "password123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful login",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "token": { "type": "string", "example": "pep-dttot-secret-token" }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/v1/dttot/check": {
      "post": {
        "summary": "Cek data DTTOT",
        "description": "Mengecek apakah nama calon debitur atau NIK terindikasi dalam data DTTOT.",
        "tags": ["Pengecekan"],
        "security": [ { "bearerAuth": [] } ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "nama": { "type": "string", "description": "Nama calon debitur" },
                  "nik": { "type": "string", "description": "NIK calon debitur" }
                }
              }
            },
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nama": { "type": "string" },
                  "nik": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Hasil pengecekan",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "status": { "type": "string" },
                    "message": { "type": "string" },
                    "matches": { "type": "array", "items": { "type": "object" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/pep/check": {
      "post": {
        "summary": "Pengecekan PEP",
        "description": "Pengecekan terhadap scraper PPATK eksternal dengan fallback otomatis ke database internal.",
        "tags": ["Pengecekan"],
        "security": [ { "bearerAuth": [] } ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "nama": { "type": "string" },
                  "nik": { "type": "string" }
                }
              }
            },
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nama": { "type": "string" },
                  "nik": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Hasil Pengecekan PEP",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "status": { "type": "string" },
                    "source": { "type": "string" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
